  "keyFeatures": [
    "Serialize Java records to Parquet files using reflection",
    "Deserialize Parquet files back to Java records",
    "Support for nested records, Collections, and Maps",
    "Column name aliasing and snake_case conversion strategies",
    "Partial projection reads for I/O efficiency",
    "Write Model API for non-record classes and custom field mapping",
    "Support for temporal types, BigDecimal, UUID, Binary, and geospatial data",
    "Java type annotations for JSON, BSON, Enum, and Decimal precision control",
    "Low-level ParquetWriter/ParquetReader access for third-party library integration",
    "Minimal Hadoop transitive dependencies"
  ],
